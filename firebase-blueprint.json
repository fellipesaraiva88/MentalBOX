{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile photo URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the system." }
      },
      "required": ["uid", "email"]
    },
    "Item": {
      "title": "App Item",
      "description": "A unified entity for tasks, projects, notes, ideas, and reminders.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["ideia", "tarefa", "insight", "melhoria", "projeto"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "status": { "type": "string", "enum": ["capturado", "em_analise", "direcao_ativa", "incubado", "concluido", "arquivado"] },
        "context": { "type": "string", "enum": ["produto", "conteudo", "operacao", "pessoal", "geral"] },
        "projectId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "attachments": { "type": "array", "items": { "type": "object" } },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "required": ["id", "uid", "type", "title", "createdAt", "updatedAt", "status"]
    },
    "CommandHistory": {
      "title": "Command History",
      "description": "History of user commands and AI responses.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "command": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "number" },
        "undoData": { "type": "string" }
      },
      "required": ["id", "uid", "command", "response", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/items/{itemId}": {
      "schema": "Item",
      "description": "Collection of items for a specific user."
    },
    "/users/{userId}/commands/{commandId}": {
      "schema": "CommandHistory",
      "description": "Collection of command history for a specific user."
    }
  }
}
