// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /users/{userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - photoURL: string
//   - role: string (user, admin)
//
// Collection: /users/{userId}/items/{itemId}
// Fields:
//   - id: string (required)
//   - uid: string (required)
//   - type: string (ideia, tarefa, insight, melhoria, projeto) (required)
//   - title: string (required)
//   - content: string
//   - createdAt: number (required)
//   - updatedAt: number (required)
//   - status: string (capturado, em_analise, direcao_ativa, incubado, concluido, arquivado) (required)
//   - context: string (produto, conteudo, operacao, pessoal, geral)
//   - projectId: string
//   - tags: array
//   - attachments: array
//   - priority: string
//
// Collection: /users/{userId}/commands/{commandId}
// Fields:
//   - id: string (required)
//   - uid: string (required)
//   - command: string (required)
//   - response: string (required)
//   - timestamp: number (required)
//   - undoData: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidItem(data) {
      return data.id is string &&
             data.uid == request.auth.uid &&
             data.type in ['ideia', 'tarefa', 'insight', 'melhoria', 'projeto'] &&
             data.title is string && data.title.size() < 500 &&
             (!('content' in data) || (data.content is string && data.content.size() < 50000)) &&
             data.createdAt is number &&
             data.updatedAt is number &&
             data.status in ['capturado', 'em_analise', 'direcao_ativa', 'incubado', 'concluido', 'arquivado'];
    }

    function isValidCommand(data) {
      return data.id is string &&
             data.uid == request.auth.uid &&
             data.command is string && data.command.size() < 10000 &&
             data.response is string && data.response.size() < 50000 &&
             data.timestamp is number;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "fellipesaraivabarbosa@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      
      match /items/{itemId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidItem(request.resource.data);
        allow update: if isOwner(userId) && isValidItem(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /commands/{commandId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidCommand(request.resource.data);
        allow update: if isOwner(userId) && isValidCommand(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
