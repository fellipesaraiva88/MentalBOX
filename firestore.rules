// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /users/{userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string
//   - photoURL: string
//   - role: string (user, admin)
//
// Collection: /users/{userId}/thoughts/{thoughtId}
// Fields:
//   - id: string (required)
//   - uid: string (required)
//   - content: string (required)
//   - createdAt: number (required)
//   - status: string (raw, action, future, reference, discarded)
//   - kanbanStatus: string (todo, doing, done)
//   - aiSummary: string
//   - attachments: array of objects
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidThought(data) {
      return data.id is string &&
             data.uid == request.auth.uid &&
             data.content is string && data.content.size() < 10000 &&
             data.createdAt is number &&
             data.status in ['raw', 'action', 'future', 'reference', 'discarded'];
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "fellipesaraivabarbosa@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      
      match /thoughts/{thoughtId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidThought(request.resource.data);
        allow update: if isOwner(userId) && isValidThought(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
